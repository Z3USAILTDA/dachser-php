# ───────────────────────────────────────────────────────────────────────────
# Exemplo de variáveis de ambiente. Copie para `.env` e preencha os valores.
# NUNCA faça commit do `.env` com segredos reais (já está no .gitignore).
# ───────────────────────────────────────────────────────────────────────────
#
# ARQUITETURA DE POOLS POR FASE
# ─────────────────────────────
# Cada fase da migração usa seu próprio conjunto de variáveis MARIADB_<FASE>_*.
# Isso permite que cada módulo aponte para servidores/credenciais diferentes
# sem afetar os outros. Se todas as fases estiverem no mesmo servidor, basta
# preencher os mesmos valores em cada bloco.
#
# O backend (server/index.js) cria pools lazy: um pool por fase, inicializado
# apenas quando a primeira requisição daquela fase chegar.
#
# Databases utilizados:
#   dados_dachser → dados operacionais (air, sea, vouchers, demurrage, etc.)
#   ai_agente     → auth, logs de uso, CHB/IA, monitoramento

SERVER_PORT="3001"

# --- Backend Olimpo (MariaDB) ---
# Usado SOMENTE pelo server/index.js. O frontend chama apenas /api/olimpo/*.
MARIADB_OLIMPO_HOST="localhost"
MARIADB_OLIMPO_PORT="3306"
MARIADB_OLIMPO_DATABASE="dados_dachser"
MARIADB_OLIMPO_USER="seu_usuario"
MARIADB_OLIMPO_PASSWORD="sua_senha"
MAPBOX_PUBLIC_TOKEN=""
FLIGHTRADAR_API_KEY=""

# Aliases equivalentes (opcionais) — o backend aceita qualquer um dos conjuntos:
# DB_HOST="localhost"
# DB_PORT="3306"
# DB_NAME="dados_dachser"
# DB_USER="seu_usuario"
# DB_PASSWORD="sua_senha"

# ─── Frontend (público) ───
# Opcional. Vazio = caminho relativo (/api/...). Defina apenas se a API rodar em
# outra origem (ex.: https://api.seu-dominio.com). NUNCA coloque credenciais aqui.
VITE_API_BASE_URL=""

# ─── Supabase (legado — remover após migração completa) ──────────────────────
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""

# ═══════════════════════════════════════════════════════════════════════════════
#  FASE 1 — AUTH  |  database: dados_dachser
#  Endpoints: POST /api/auth/login, /forgot-password, /verify-reset-code,
#             /reset-password, /change-password
# ═══════════════════════════════════════════════════════════════════════════════
MARIADB_AUTH_HOST="localhost"
MARIADB_AUTH_PORT="3306"
MARIADB_AUTH_DATABASE="dados_dachser"
MARIADB_AUTH_USER="seu_usuario_auth"
MARIADB_AUTH_PASSWORD="sua_senha_auth"

# Tabelas usadas pela auth — sobrescreva se os nomes diferirem
AUTH_USERS_TABLE="dados_dachser.t_users_dachser"
AUTH_CODES_TABLE="dados_dachser.t_password_reset"

# Resend — envio de e-mail de recuperação de senha (somente backend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Nome Sistema <noreply@seu-dominio.com>"

# ═══════════════════════════════════════════════════════════════════════════════
#  FASE 2 — AIR TRACKING  |  database: dados_dachser
#  Endpoints: GET /api/air/tracking-aereo, /filters, /summary
#             POST /api/air/master-swaps, /usage-log
# ═══════════════════════════════════════════════════════════════════════════════
MARIADB_AIR_HOST="localhost"
MARIADB_AIR_PORT="3306"
MARIADB_AIR_DATABASE="dados_dachser"
MARIADB_AIR_USER="seu_usuario_air"
MARIADB_AIR_PASSWORD="sua_senha_air"

# Janela de dados: processa ETDs a partir desta data (YYYY-MM-DD)
AIR_ETD_CUTOFF="2026-06-01"

# ═══════════════════════════════════════════════════════════════════════════════
#  FASE 3 — ESTEIRA / VOUCHERS  |  database: dados_dachser
#  Endpoints: (a implementar) /api/esteira/*
# ═══════════════════════════════════════════════════════════════════════════════
MARIADB_SEA_HOST="localhost"
MARIADB_SEA_PORT="3306"
MARIADB_SEA_DATABASE="dados_dachser"
MARIADB_SEA_USER="seu_usuario_sea"
MARIADB_SEA_PASSWORD="sua_senha_sea"

# ═══════════════════════════════════════════════════════════════════════════════
#  FASE 4 — RASCUNHO / MARÍTIMO  |  database: dados_dachser
#  Endpoints: (a implementar) /api/sea/draft/*
# ═══════════════════════════════════════════════════════════════════════════════
MARIADB_DRAFT_HOST="localhost"
MARIADB_DRAFT_PORT="3306"
MARIADB_DRAFT_DATABASE="dados_dachser"
MARIADB_DRAFT_USER="seu_usuario_draft"
MARIADB_DRAFT_PASSWORD="sua_senha_draft"

# ═══════════════════════════════════════════════════════════════════════════════
#  FASE 5 — ADMIN / MÉTRICAS  |  database: ai_agente
#  Endpoints: (a implementar) /api/admin/*
# ═══════════════════════════════════════════════════════════════════════════════
MARIADB_ADMIN_HOST="localhost"
MARIADB_ADMIN_PORT="3306"
MARIADB_ADMIN_DATABASE="ai_agente"
MARIADB_ADMIN_USER="seu_usuario_admin"
MARIADB_ADMIN_PASSWORD="sua_senha_admin"

# ═══════════════════════════════════════════════════════════════════════════════
#  FASE 6 — OPS (Demurrage, CCT, CHB, Olimpo)  |  dados_dachser + ai_agente
#  Endpoints: (a implementar) /api/ops/*
# ═══════════════════════════════════════════════════════════════════════════════
MARIADB_OPS_HOST="localhost"
MARIADB_OPS_PORT="3306"
MARIADB_OPS_DATABASE="dados_dachser"
MARIADB_OPS_USER="seu_usuario_ops"
MARIADB_OPS_PASSWORD="sua_senha_ops"

# ═══════════════════════════════════════════════════════════════════════════════
#  LLM API KEYS  (somente backend — NUNCA expor no frontend)
#  Usadas pelos endpoints /api/chb/* e /api/chb/compare-documents
# ═══════════════════════════════════════════════════════════════════════════════
# Google Gemini — substitui o Lovable AI Gateway
GEMINI_API_KEY="sua-chave-gemini-aqui"
# Anthropic Claude — comparação de documentos CHB e análise marítima
ANTHROPIC_API_KEY="sua-chave-anthropic-aqui"
# OpenAI — arbitragem GPT-4.1 em sea-submit-analysis (necessária ao migrar essa edge function)
OPENAI_API_KEY="sua-chave-openai-aqui"
