# ───────────────────────────────────────────────────────────────────────────
# Exemplo de variáveis de ambiente. Copie para `.env` e preencha os valores.
# NUNCA faça commit do `.env` com segredos reais (já está no .gitignore).
# ───────────────────────────────────────────────────────────────────────────

# ─── Backend tracking-aereo (MariaDB) — usado SOMENTE pelo server/index.js ───
# Estas credenciais NUNCA vão para o frontend. O React só fala com /api/air/*.
MARIADB_AIR_HOST="localhost"
MARIADB_AIR_PORT="3306"
MARIADB_AIR_DATABASE="dados_dachser"
MARIADB_AIR_USER="seu_usuario"
MARIADB_AIR_PASSWORD="sua_senha"
SERVER_PORT="3001"
# Janela de dados da tela air/tracking-aereo: traz processos com ETD a partir desta data (YYYY-MM-DD).
AIR_ETD_CUTOFF="2026-06-01"

# Aliases equivalentes (opcionais) — o backend aceita qualquer um dos conjuntos:
# DB_HOST="localhost"
# DB_PORT="3306"
# DB_NAME="dados_dachser"
# DB_USER="seu_usuario"
# DB_PASSWORD="sua_senha"

# ─── Frontend (público) ───
# Opcional. Vazio = caminho relativo (/api/...). Defina apenas se a API rodar em
# outra origem (ex.: https://api.seu-dominio.com). NUNCA coloque credenciais aqui.
VITE_API_BASE_URL=""

# ─── Supabase (legado) ───
# Ainda usado por telas NÃO migradas. A tela air/tracking-aereo não usa mais.
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""
